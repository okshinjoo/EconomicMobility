# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Local Claude Code session settings (keep launch.json, ignore local perms)
.claude/settings.local.json

# iCloud/Finder duplicate junk ("file 2.ts") — appears via cloud sync, never commit
* [0-9].ts
* [0-9].tsx
* [0-9].js
* [0-9].json
* [0-9].md
